{
  "name": "css-spec",
  "version": "0.2.2",
  "description": "Dev-only Figma-style CSS design-spec overlay for Next.js App Router. Hover to inspect, edit design tokens live, and copy precise prompts for your AI coding tool.",
  "type": "module",
  "types": "./dist/client/index.d.ts",
  "bin": {
    "css-spec": "./dist/cli/init.js"
  },
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./style.css": "./dist/client/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/client/index.js",
    "./dist/client/index.cjs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "postinstall": "node ./dist/cli/postinstall.js || true"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "postcss": "^8.4.31"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "next": "^15.5.12",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namuloves/myportfolio.git",
    "directory": "packages/css-spec"
  },
  "license": "MIT",
  "keywords": [
    "css",
    "design-tokens",
    "design-spec",
    "overlay",
    "inspector",
    "nextjs",
    "dev-tools",
    "claude-code"
  ]
}
